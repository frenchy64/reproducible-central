groupId=org.clojure
artifactId=clojure
display=${groupId}:${artifactId}
version=1.2.0

gitRepo=https://github.com/clojure/clojure.git
gitTag=${version}

tool=mvn-3.9.11
jdk=8
newline=lf
umask=022

command="mv pom-template.xml pom.xml && mvn versions:set -DnewVersion=1.2.0 &&  mvn clean package -Dmaven.test.skip=true -Dmaven.javadoc.skip -Dgpg.skip"
buildinfo=target/${artifactId}-${version}.buildinfo

diffoscope=${artifactId}-${version}.diffoscope
issue=
